# =============================================================================
# matrix-starter theme — copy to .env and adjust per Local site
# =============================================================================

# --- Site URLs (Playwright, a11y, link checks) ---
WP_HOME=http://localhost:10029/
BASE_URL=http://localhost:10029/

# --- WordPress root (flexi-install, WP-CLI) — required for reliable installs outside Local shell ---
WP_PATH="/Users/bernardhanna/Local Sites/rollingdonut/app/public"

# --- flexi-install: WP-CLI timeouts (optional) ---
WP_TIMEOUT=15
WP_TIMEOUT_INSTALL=180

# --- flexi-install: Password Protected ---
# Script sets: site lock ON, allow admins, remember me 21 days.
# Default password in script: matrix + current year (e.g. matrix2026) — crawler/staging only.
# MATRIX_SITE_PASSWORD=matrix2026

# --- flexi-install: WP Mail SMTP (Google / Gmail) ---
# Script applies when MATRIX_SMTP_GOOGLE_CLIENT_SECRET is set below.
# Google OAuth redirect URI (Cloud Console): https://connect.wpmailsmtp.com/google/
MATRIX_SMTP_FROM_EMAIL=devs@matrixinternet.ie
MATRIX_SMTP_FROM_NAME=
MATRIX_PROJECT_NAME=
MATRIX_SMTP_GOOGLE_CLIENT_ID=759522357864-kbds2oh9meatcsjiqfd35obhpvrt08s9.apps.googleusercontent.com
MATRIX_SMTP_GOOGLE_CLIENT_SECRET=

# --- Theme front-end dev (webpack) ---
DEV_SERVER_PORT=3000

# --- Database (optional; Local uses wp-config.php / socket — usually leave empty) ---
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
